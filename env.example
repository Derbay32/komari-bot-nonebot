HOST=0.0.0.0
PORT=8080
DRIVER=~fastapi
FASTAPI_DOCS_URL=/api/komari-management/docs
FASTAPI_OPENAPI_URL=/api/komari-management/openapi.json
FASTAPI_REDOC_URL=
FASTAPI_INCLUDE_ADAPTER_SCHEMA=false

# 用户数据插件配置
USER_DATA_DB_PATH=user_data.db
USER_DATA_DB_POOL_SIZE=5
USER_DATA_DATA_RETENTION_DAYS=30

# 命令格式
COMMAND_START=["。", "."]
COMMAND_SEP=[" "]

# 本地配置存储插件配置，默认存储于工作目录
LOCALSTORE_USE_CWD=True

SUPERUSERS=[]

# huggingface用的，不知道有啥用，但不写它就会写日志使我心情减8
TOKENIZERS_PARALLELISM=false

# sentry 配置，不用可以不写，要用记得去掉注释
# SENTRY_DSN=
